# ── AI ─────────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-2.0-flash

# ── Gmail OAuth ─────────────────────────────────────────────────────────────────
GMAIL_USER=shawada6@gmail.com
# token.json (generated by tools/auth_gmail.py) encoded as base64 for cloud deploy
# Windows: certutil -encode token.json token_b64.txt  →  copy content here
# Linux:   base64 -w0 token.json
GMAIL_TOKEN_B64=

# ── RSS & Routing ───────────────────────────────────────────────────────────────
RSS_FEEDS=https://example.com/feed1,https://example.com/feed2
RECIPIENT_EMAIL=recipient@gmail.com
RSS_POLL_INTERVAL=60
MAX_ARTICLES_PER_CYCLE=3

# ── Branding ────────────────────────────────────────────────────────────────────
LOGO_PATH=assets/logo.png
BRAND_COLOR_PRIMARY=#E60000
BRAND_COLOR_ACCENT=#FFFFFF
